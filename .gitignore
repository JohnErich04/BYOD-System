# Ignore compiled Java classes and build artifacts
target/**/*.class
target/maven-archiver/
target/maven-status/

# Allow Git to look into your specific fxml folder
!target/classes/fxml/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
.kotlin

